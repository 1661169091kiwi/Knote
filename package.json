{
  "name": "knote",
  "private": true,
  "version": "1.0.2",
  "description": "Knote — 类飞书的 Markdown 笔记应用（内置 AI 助手）",
  "author": "KV",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "app:dev": "electron .",
    "dist:win": "vite build && electron-builder --win",
    "cap:sync": "cap sync android && node scripts/set-android-version.mjs && node scripts/fix-android-java.mjs",
    "dist:apk": "vite build && cap sync android && node scripts/set-android-version.mjs && node scripts/fix-android-java.mjs && cd android && gradlew.bat assembleDebug"
  },
  "build": {
    "appId": "com.kv.knote",
    "productName": "Knote",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "sidecar",
        "to": "sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "Knote.Markdown",
        "description": "Markdown 文档",
        "role": "Editor"
      },
      {
        "ext": "markdown",
        "name": "Knote.Markdown",
        "description": "Markdown 文档",
        "role": "Editor"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Knote"
    }
  },
  "dependencies": {
    "@capacitor/android": "8.2.0",
    "@capacitor/cli": "8.2.0",
    "@capacitor/core": "8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@mozilla/readability": "^0.6.0",
    "@tiptap/extension-code-block-lowlight": "^2.27.2",
    "@tiptap/extension-color": "^2.27.2",
    "@tiptap/extension-highlight": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-mathematics": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-text-style": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/vue-3": "^2.27.2",
    "@vscode/markdown-it-katex": "^1.1.2",
    "dompurify": "^3.3.1",
    "highlight.js": "^11.11.1",
    "jsdom": "^28.1.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.47",
    "lowlight": "^3.3.0",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.16.0",
    "pdfjs-dist": "^6.1.200",
    "tiptap-markdown": "^0.8.10",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.24",
    "daisyui": "^5.5.18",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.4"
  }
}
